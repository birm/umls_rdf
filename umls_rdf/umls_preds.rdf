@prefix umls: <http://bioportal.bioontology.org/ontologies/umls/> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

### UMLS General Predicate, Mapping fallthrough. ###

umls:sourceCode rdf:type owl:DatatypeProperty ;
    rdfs:label "sourceCode" ;
    rdfs:comment "The identifier from the original source vocabulary, formatted as SAB:CODE. Fallthough for code systems where a URI was not constructed. See owl:sameAs for URI-mapped source codes." ;
    rdfs:subPropertyOf skos:notation ;
    rdfs:range xsd:string .

### UMLS Relationship Predicates ###

# RO: Other Relationship
umls:RO rdf:type owl:ObjectProperty ;
    rdfs:label "RO" ;
    skos:definition "Has relationship other than synonymous, narrower, or broader" ;
    rdfs:subPropertyOf skos:related ;
    owl:inverseOf umls:RO .

# PAR and CHD: Hierarchical (Parent/Child)
umls:PAR rdf:type owl:ObjectProperty ;
    rdfs:label "PAR" ;
    skos:definition "Has parent relationship in a Metathesaurus source vocabulary" ;
    rdfs:subPropertyOf skos:broader ;
    owl:inverseOf umls:CHD .

umls:CHD rdf:type owl:ObjectProperty ;
    rdfs:label "CHD" ;
    skos:definition "Has child relationship in a Metathesaurus source vocabulary" ;
    rdfs:subPropertyOf skos:narrower ;
    owl:inverseOf umls:PAR .

# RB and RN: Broader/Narrower
umls:RB rdf:type owl:ObjectProperty ;
    rdfs:label "RB" ;
    skos:definition "Has a broader relationship" ;
    rdfs:subPropertyOf skos:broader ;
    owl:inverseOf umls:RN .

umls:RN rdf:type owl:ObjectProperty ;
    rdfs:label "RN" ;
    skos:definition "Has a narrower relationship" ;
    rdfs:subPropertyOf skos:narrower ;
    owl:inverseOf umls:RB .

# QB and AQ: Qualification
umls:QB rdf:type owl:ObjectProperty ;
    rdfs:label "QB" ;
    skos:definition "Can be qualified by" ;
    owl:inverseOf umls:AQ .

umls:AQ rdf:type owl:ObjectProperty ;
    rdfs:label "AQ" ;
    skos:definition "Allowed qualifier" ;
    owl:inverseOf umls:QB .

# RL: Alike/Similar
umls:RL rdf:type owl:ObjectProperty ;
    rdfs:label "RL" ;
    skos:definition "The relationship is similar or alike" ;
    rdfs:subPropertyOf skos:closeMatch ;
    owl:inverseOf umls:RL .

# SY: Source Synonymy
umls:SY rdf:type owl:ObjectProperty ;
    rdfs:label "SY" ;
    skos:definition "Source asserted synonymy" ;
    rdfs:subPropertyOf skos:exactMatch ;
    owl:inverseOf umls:SY .

# RQ: Related/Possibly Synonymous
umls:RQ rdf:type owl:ObjectProperty ;
    rdfs:label "RQ" ;
    skos:definition "Related and possibly synonymous" ;
    rdfs:subPropertyOf skos:related ;
    owl:inverseOf umls:RQ .